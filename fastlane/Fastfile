default_platform(:ios)

def resolved_project_file(default_project)
  env_project = ENV["CICD_PROJECT_FILE"]
  return env_project if env_project && !env_project.empty? && File.exist?(env_project)
  return default_project if File.exist?(default_project)

  detected = Dir.glob("*.xcodeproj").first
  return detected unless detected.nil? || detected.empty?

  default_project
end

def resolved_scheme(default_scheme)
  env_scheme = ENV["CICD_DEFAULT_SCHEME"]
  return env_scheme if env_scheme && !env_scheme.empty?

  project = resolved_project_file("#{default_scheme}.xcodeproj")
  return File.basename(project, ".xcodeproj") if project.end_with?(".xcodeproj")

  default_scheme
end

platform :ios do

  desc "Build app (CI)"
  lane :build do
    project = resolved_project_file("CI_CD_Project.xcodeproj")
    scheme  = resolved_scheme("CI_CD_Project")
    config  = ENV["CICD_DEFAULT_CONFIGURATION"] || "Debug"

    build_app(
      project: project,
      scheme: scheme,
      configuration: config,
      clean: true,
      skip_package_ipa: true
    )
  end

  desc "Run unit tests"
  lane :test do
    project = resolved_project_file("CI_CD_Project.xcodeproj")
    scheme  = resolved_scheme("CI_CD_Project")
    dest    = ENV["CICD_TEST_DESTINATION"] || "platform=iOS Simulator,name=iPhone 15"

    run_tests(
      project: project,
      scheme: scheme,
      destination: dest
    )
  end

  desc "Release build to TestFlight"
  lane :release do
    project = ENV["CICD_PROJECT_FILE"]
    scheme  = ENV["CICD_DEFAULT_SCHEME"]
    notes   = ENV["RELEASE_NOTES"] || ""

    match(type: "appstore", readonly: true)

    build_app(
      project: project,
      scheme: scheme,
      configuration: "Release",
      clean: true
    )

    upload_to_testflight(
      changelog: notes,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Build (ad-hoc) and distribute to Firebase App Distribution"
  lane :firebase_distribute do
    project = resolved_project_file("cicd.xcodeproj")
    scheme  = resolved_scheme("cicd")
    config  = ENV["CICD_DEFAULT_CONFIGURATION"] || "Debug"
    app_id  = ENV["FIREBASE_APP_ID"]
    groups  = ENV["FIREBASE_GROUPS"] || "testers"
    notes   = ENV["RELEASE_NOTES"] || "Build #{last_git_commit[:abbreviated_commit_hash]} on #{git_branch}"

    UI.user_error!("FIREBASE_APP_ID must be set") if app_id.nil? || app_id.empty?

    match(type: "adhoc", readonly: true)

    build_app(
      project: project,
      scheme: scheme,
      configuration: config,
      clean: true,
      export_method: "ad-hoc"
    )

    firebase_app_distribution(
      app: app_id,
      groups: groups,
      release_notes: notes,
      firebase_cli_token: ENV["FIREBASE_CLI_TOKEN"]
    )
  end

end
